{
  // Mainnet fork configuration for IssuanceAllocator
  // For testing against a forked version of Arbitrum One mainnet

  // Core deployment parameters (using real mainnet addresses for testing)
  owner: '0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266', // First Hardhat account (for fork testing)
  graphToken: '0x9623063377AD1B27544C965cCd7342f7EA7e88C7', // Real GRT token on Arbitrum One

  // Network information
  network: {
    name: 'fork',
    chainId: 42161, // Same as Arbitrum One (forked)
    description: 'Arbitrum One mainnet fork',
    isTestnet: true, // Treated as testnet for safety
    blockTime: 0.25, // ~250ms on Arbitrum
    rpcUrl: 'http://127.0.0.1:8545', // Local fork URL
    forkUrl: 'https://arb1.arbitrum.io/rpc', // Source network to fork
    forkBlockNumber: 'latest', // Fork from latest block (or specify block number)
  },

  // Deployment configuration
  deployment: {
    confirmations: 1, // Fast confirmations for fork testing
    gasPrice: 'auto', // Let network handle gas pricing
    gasLimit: 'auto', // Let network handle gas limits
    timeout: 120000, // 2 minutes timeout for fork deployment
  },

  // IssuanceAllocator specific parameters
  issuanceAllocator: {
    // Initial configuration (can be updated via governance)
    initialIssuancePerBlock: '100000000000000000000', // 100 GRT per block (mainnet rate)

    // Governance settings (using test account for fork)
    governor: '0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266', // Test account for fork testing

    // Testing flags
    enableTestingFeatures: true, // Enable testing features on fork
    skipInitialValidation: false,
  },

  // Contract addresses for fork (real mainnet addresses)
  contracts: {
    // Core Graph Protocol contracts on Arbitrum One (real addresses)
    graphToken: '0x9623063377AD1B27544C965cCd7342f7EA7e88C7', // Real GRT token
    rewardsManager: '0x9aC758AB77733B4150a901ebd659cbf8fb93eDAE', // Real RewardsManager

    // Fork testing accounts (impersonated accounts)
    forkAccounts: {
      deployer: '0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266', // Test deployer
      governance: '0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266', // Test governance

      // Real mainnet accounts that can be impersonated for testing
      realGovernance: '0x0000000000000000000000000000000000000000', // TODO: Real governance address
      realTreasury: '0x0000000000000000000000000000000000000000', // TODO: Real treasury address

      // Test accounts
      operator1: '0x70997970C51812dc3A010C7d01b50e0d17dc79C8',
      operator2: '0x3C44CdDdB6a900fa2b585dd299e03d12FA4293BC',
    },
  },

  // Fork-specific settings
  fork: {
    // Impersonation settings
    impersonateAccounts: [
      '0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266', // Test accounts
      // Add real mainnet accounts to impersonate for testing
    ],

    // Account funding (give test accounts ETH)
    fundAccounts: {
      '0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266': '1000000000000000000000', // 1000 ETH
      '0x70997970C51812dc3A010C7d01b50e0d17dc79C8': '100000000000000000000', // 100 ETH
      '0x3C44CdDdB6a900fa2b585dd299e03d12FA4293BC': '100000000000000000000', // 100 ETH
    },

    // Fork configuration
    resetBetweenTests: true, // Reset fork state between test runs
    cacheEnabled: true, // Cache fork state for faster testing
    unlockAccounts: true, // Unlock accounts for testing
  },

  // Verification settings
  verification: {
    enabled: false, // No verification needed for fork testing
    apiKey: '', // Not needed for fork
    apiUrl: '', // Not needed for fork
  },

  // Development utilities
  development: {
    saveDeploymentInfo: true, // Save deployment addresses for testing
    logLevel: 'debug', // Verbose logging for fork testing
    enableGasReporting: true, // Track gas usage
    enableCoverage: false, // Disable coverage by default
    enableTracing: true, // Enable transaction tracing for debugging

    // Fork-specific debugging
    forkDebugging: {
      logImpersonation: true, // Log account impersonation
      logStateChanges: true, // Log state changes
      saveSnapshots: true, // Save fork snapshots for debugging
    },
  },

  // Environment requirements
  requirements: {
    // Required environment variables
    envVars: [
      'ARBITRUM_ONE_URL', // RPC URL for forking Arbitrum One
      // No private key needed - using impersonated accounts
    ],

    // Fork-specific requirements
    forkRequirements: [
      'validRPCConnection', // Must have valid RPC connection to fork from
      'sufficientDiskSpace', // Fork requires disk space for state
      'fastRPCProvider', // Recommend fast RPC provider for better performance
    ],
  },
}
