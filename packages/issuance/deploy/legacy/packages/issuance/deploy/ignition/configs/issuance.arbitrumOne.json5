{
  // Arbitrum One mainnet configuration for IssuanceAllocator
  // PRODUCTION DEPLOYMENT - All parameters must be carefully reviewed

  // Core deployment parameters
  owner: '0x0000000000000000000000000000000000000000', // MUST BE SET: Graph Protocol governance address
  graphToken: '0x9623063377AD1B27544C965cCd7342f7EA7e88C7', // GRT token on Arbitrum One (verified)

  // Network information
  network: {
    name: 'arbitrumOne',
    chainId: 42161,
    description: 'Arbitrum One mainnet',
    isTestnet: false,
    blockTime: 0.25, // ~250ms on Arbitrum
    rpcUrl: 'https://arb1.arbitrum.io/rpc',
    explorerUrl: 'https://arbiscan.io',
  },

  // Deployment configuration
  deployment: {
    confirmations: 5, // Wait for 5 confirmations on mainnet
    gasPrice: 'auto', // Let network handle gas pricing
    gasLimit: 'auto', // Let network handle gas limits
    timeout: 600000, // 10 minutes timeout for mainnet deployment
  },

  // IssuanceAllocator specific parameters
  issuanceAllocator: {
    // Initial configuration (can be updated via governance)
    initialIssuancePerBlock: '100000000000000000000', // 100 GRT per block (REVIEW: Production rate)

    // Governance settings (CRITICAL: Must be set correctly)
    governor: '0x0000000000000000000000000000000000000000', // MUST BE SET: Graph Protocol governance

    // Production flags
    enableTestingFeatures: false, // Disable testing features on mainnet
    skipInitialValidation: false, // Always validate on mainnet
  },

  // Contract addresses for Arbitrum One
  contracts: {
    // Core Graph Protocol contracts on Arbitrum One (verified addresses)
    graphToken: '0x9623063377AD1B27544C965cCd7342f7EA7e88C7', // GRT token (verified)

    // Known mainnet contracts
    rewardsManager: '0x9aC758AB77733B4150a901ebd659cbf8fb93eDAE', // RewardsManager (verified)

    // Governance contracts (TODO: Add actual governance addresses)
    governance: '0x0000000000000000000000000000000000000000', // MUST BE SET: Governance contract

    // Production accounts (all must be set)
    productionAccounts: {
      deployer: '0x0000000000000000000000000000000000000000', // MUST BE SET: Deployer account
      governance: '0x0000000000000000000000000000000000000000', // MUST BE SET: Governance account
      treasury: '0x0000000000000000000000000000000000000000', // MUST BE SET: Treasury account
    },
  },

  // Verification settings
  verification: {
    enabled: true, // REQUIRED: Always verify contracts on mainnet
    apiKey: 'ARBISCAN_API_KEY', // Environment variable for Arbiscan API key
    apiUrl: 'https://api.arbiscan.io/api',
    explorerUrl: 'https://arbiscan.io',
  },

  // Production settings
  production: {
    saveDeploymentInfo: true, // REQUIRED: Save deployment info for tracking
    logLevel: 'warn', // Minimal logging for production
    enableGasReporting: true, // Track gas usage for optimization
    enableCoverage: false, // Disable coverage on mainnet
    requireConfirmation: true, // REQUIRED: Manual confirmation for all operations
    enableEmergencyPause: true, // Enable emergency pause functionality
  },

  // Security settings
  security: {
    // Multi-signature requirements
    requireMultiSig: true, // REQUIRED: All governance operations must use multi-sig
    minSignatures: 3, // Minimum signatures required

    // Time delays
    governanceDelay: 172800, // 48 hours delay for governance actions (seconds)
    emergencyDelay: 86400, // 24 hours delay for emergency actions (seconds)

    // Access controls
    restrictedFunctions: [
      'upgrade', // Proxy upgrades require governance
      'setIssuancePerBlock', // Issuance rate changes require governance
      'pause', // Pausing requires governance
    ],
  },

  // Environment requirements
  requirements: {
    // Required environment variables
    envVars: [
      'ARBITRUM_ONE_URL', // RPC URL for Arbitrum One
      'PRIVATE_KEY', // Deployer private key (should be hardware wallet)
      'ARBISCAN_API_KEY', // For contract verification
    ],

    // Required parameter validation
    requiredParams: [
      'owner', // Must set governance address
      'graphToken', // Must be verified GRT address
    ],

    // Security checks
    securityChecks: [
      'verifyGovernanceAddress', // Verify governance address is correct
      'verifyGraphTokenAddress', // Verify GRT token address is correct
      'checkDeployerBalance', // Ensure deployer has sufficient ETH
      'validateNetworkId', // Ensure deploying to correct network
    ],
  },
}
