{
  // Ethereum Sepolia testnet configuration for IssuanceAllocator
  // For testing on Ethereum L1 before Arbitrum deployment

  // Core deployment parameters
  owner: '0x0000000000000000000000000000000000000000', // MUST BE SET: Governance address
  graphToken: '0x0000000000000000000000000000000000000000', // MUST BE SET: GRT token on Sepolia

  // Network information
  network: {
    name: 'sepolia',
    chainId: 11155111,
    description: 'Ethereum Sepolia testnet',
    isTestnet: true,
    blockTime: 12, // ~12 seconds on Ethereum
    rpcUrl: 'https://sepolia.infura.io/v3/YOUR_INFURA_KEY',
    explorerUrl: 'https://sepolia.etherscan.io',
  },

  // Deployment configuration
  deployment: {
    confirmations: 3, // Wait for 3 confirmations on testnet
    gasPrice: 'auto', // Let network handle gas pricing
    gasLimit: 'auto', // Let network handle gas limits
    timeout: 600000, // 10 minutes timeout (Ethereum is slower)
  },

  // IssuanceAllocator specific parameters
  issuanceAllocator: {
    // Initial configuration (can be updated via governance)
    initialIssuancePerBlock: '10000000000000000000', // 10 GRT per block (lower for Ethereum)

    // Governance settings (MUST BE SET for testnet)
    governor: '0x0000000000000000000000000000000000000000', // MUST BE SET: Testnet governance

    // Testing flags
    enableTestingFeatures: true, // Enable testing features on testnet
    skipInitialValidation: false,
  },

  // Contract addresses for Sepolia
  contracts: {
    // Core Graph Protocol contracts (TODO: Add actual testnet addresses)
    graphToken: '0x0000000000000000000000000000000000000000', // MUST BE SET: GRT on Sepolia

    // Known testnet contracts (if any)
    // rewardsManager: "0x0000000000000000000000000000000000000000", // Optional: RewardsManager if deployed

    // Test accounts (example addresses - replace with actual testnet accounts)
    testAccounts: {
      deployer: '0x0000000000000000000000000000000000000000', // MUST BE SET: Deployer account
      governance: '0x0000000000000000000000000000000000000000', // MUST BE SET: Governance account
      operator1: '0x0000000000000000000000000000000000000000', // Optional: Test operator 1
      operator2: '0x0000000000000000000000000000000000000000', // Optional: Test operator 2
    },
  },

  // Verification settings
  verification: {
    enabled: true, // Enable contract verification on testnet
    apiKey: 'ETHERSCAN_API_KEY', // Environment variable for Etherscan API key
    apiUrl: 'https://api-sepolia.etherscan.io/api',
    explorerUrl: 'https://sepolia.etherscan.io',
  },

  // Testnet settings
  testnet: {
    saveDeploymentInfo: true, // Save deployment info for tracking
    logLevel: 'info', // Standard logging for testnet
    enableGasReporting: true, // Track gas usage (important on Ethereum)
    enableCoverage: false, // Disable coverage on testnet
    requireConfirmation: true, // Require manual confirmation for sensitive operations
    faucetInfo: {
      // Information about getting testnet ETH
      url: 'https://sepoliafaucet.com/',
      note: 'Get Sepolia ETH for deployment and testing',
    },
  },

  // Environment requirements
  requirements: {
    // Required environment variables
    envVars: [
      'SEPOLIA_URL', // RPC URL for Sepolia (Infura, Alchemy, etc.)
      'PRIVATE_KEY', // Deployer private key
      'ETHERSCAN_API_KEY', // For contract verification
    ],

    // Required parameter validation
    requiredParams: [
      'owner', // Must set governance address
      'graphToken', // Must set GRT token address
    ],

    // Testnet-specific checks
    testnetChecks: [
      'checkSepoliaETHBalance', // Ensure deployer has sufficient Sepolia ETH
      'validateRPCConnection', // Ensure RPC connection works
      'checkGasPrice', // Warn if gas price is too high
    ],
  },
}
